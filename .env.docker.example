# ─────────────────────────────────────────────────────────────
# ProjectFlow — Docker Environment Variables Template
#
# Copy this file:
#   cp .env.docker.example .env.docker
# Then fill in real values before running:
#   docker compose up --build
# ─────────────────────────────────────────────────────────────

# REQUIRED: Generate a strong secret key
# Run: python3 -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=your-secret-key-here-change-this

# Set to False in production
DEBUG=False

# Hosts that Django will accept requests from
# Add your production domain here too, e.g. your-app.up.railway.app
ALLOWED_HOSTS=localhost,127.0.0.1,backend

# CORS: which frontend origins can call the API
# Add your production domain, e.g. https://your-domain.com
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:80

# DATABASE_URL is set in docker-compose.yml — don't change here
# DATABASE_URL=postgres://projectflow:projectflow_secret@db:5432/projectflow
